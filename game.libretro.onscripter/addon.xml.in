<?xml version="1.0" encoding="UTF-8"?>
<addon id="game.libretro.onscripter"
		name="ONScripter"
		version="0.2.0.2"
		provider-name="Studio O.G.A.">
	<requires>
		<import addon="game.libretro" version="1.0.0"/>
	</requires>
	<extension point="kodi.gameclient"
			library_@PLATFORM@="@LIBRARY_FILENAME@">
		<platforms></platforms>
		<extensions>txt|dat|___|ons</extensions>
		<supports_vfs>false</supports_vfs>
		<supports_standalone>false</supports_standalone>
		<supports_disc_control>false</supports_disc_control>
		<requires_opengl>false</requires_opengl>
	</extension>
	<extension point="xbmc.addon.metadata">
		<license>GPLv3+</license>
		<platform>@PLATFORM@</platform>
		<source>https://github.com/kodi-game/game.libretro.onscripter</source>
		<summary lang="en_GB">ONScripter</summary>
		<description lang="en_GB">ONScripter is a visual novel games engine compatible to NScripter.</description>
	</extension>
</addon>
